{
  "name": "execute-approved-plan",
  "description": "Self-contained public skill that logs into Itera, resolves the next dependency-ready planned pull request for an iteration task, and claims it.",
  "version": "1.2.1",
  "input": {
    "type": "object",
    "required": ["canonicalTaskId"],
    "properties": {
      "canonicalTaskId": {
        "type": "string",
        "pattern": "^[A-Z0-9]+-[1-9][0-9]*$",
        "description": "Canonical Itera task ID (for example FRONTPAGE-42)."
      },
      "plannedPullRequestId": {
        "type": "string",
        "description": "Optional explicit Itera planned pull request ID to claim instead of the next dependency-ready item."
      }
    },
    "additionalProperties": false
  },
  "behavior": {
    "installEntryPoint": "python3 install.py",
    "sessionFile": "Target-specific default; Codex ~/.codex/auth/plan_execution/iteraz.json, Claude ~/.claude/auth/plan_execution/iteraz.json, Cursor ~/.cursor/auth/plan_execution/iteraz.json, Copilot/other ${XDG_CONFIG_HOME:-~/.config}/plan_execution/auth/iteraz.json",
    "appHeader": "ITERAZ",
    "platformHeader": "WEB",
    "requiredGraphQLCalls": [
      "sendEmailVerificationCode(email)",
      "loginWithEmailMfa(identifier, code)",
      "completeEmailLoginWithTotp(challengeId, code)",
      "completeEmailLoginWithRecoveryCode(challengeId, code)",
      "beginTotpEnrollment",
      "confirmTotpEnrollment(code)",
      "refreshToken(refreshToken)",
      "socialMe",
      "getNextReadyPlannedPullRequestForTask(canonicalTaskId)",
      "getIterationTaskByCanonicalId(canonicalId)",
      "getIterationTask(taskId)",
      "generateDownloadInformation(media)",
      "claimPlannedPullRequestExecution(plannedPullRequestId, branchName)"
    ],
    "canonicalTaskID": true,
    "nextReadySelection": "Server-side via getNextReadyPlannedPullRequestForTask(canonicalTaskId), unless plannedPullRequestId is provided.",
    "specificSelection": "Task plan lookup via getIterationTaskByCanonicalId(canonicalId), then local planned pull request ID selection.",
    "claimedState": "claimPlannedPullRequestExecution",
    "branchSuggestionFormat": "itera/<canonical-task-id-lower>/pr-<position+1>",
    "prototypeCodeMediaOutputRoot": "~/.codex/artifacts/plan_execution/claims/<canonical-task-id-lower>/pr-<position>/prototype_code_media/",
    "v1ExecutionStates": [
      "PLANNED",
      "IMPLEMENTING",
      "IN_REVIEW",
      "MERGED"
    ],
    "outputContains": [
      "claimed planned pull request execution state",
      "implementation context with local prototype code media file paths when present",
      "download metadata for prototype code media artifacts",
      "explicit prototype UI implementation guidance when prototype patches are attached, including a strict instruction to never build prototype canvas routes/pages and to use canvas contents only as state references"
    ]
  },
  "output": {
    "type": "object",
    "required": [
      "status",
      "canonicalTaskId",
      "iterationTask",
      "plan"
    ],
    "properties": {
      "status": {
        "type": "string",
        "enum": [
          "SUCCESS",
          "AUTH_REQUIRED",
          "LOGIN_FAILED",
          "NOT_FOUND",
          "NO_PLAN",
          "NO_READY_PR",
          "PR_NOT_FOUND",
          "UNAVAILABLE"
        ]
      },
      "canonicalTaskId": {
        "type": "string"
      },
      "iterationTask": {
        "type": ["object", "null"],
        "properties": {
          "id": { "type": "string" },
          "canonicalId": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "plan": {
        "type": "object",
        "properties": {
          "plannedPullRequest": {
            "type": "object"
          },
          "unavailableReason": {
            "type": ["string", "null"]
          },
          "suggestedBranchName": {
            "type": ["string", "null"]
          }
        }
      },
      "implementationContext": {
        "type": ["object", "null"],
        "properties": {
          "contextError": {
            "type": ["string", "null"]
          },
          "iterationTaskContext": {
            "type": ["object", "null"]
          },
          "selectedPlannedPullRequest": {
            "type": ["object", "null"]
          },
          "currentPlan": {
            "type": ["object", "null"],
            "properties": {
              "id": {
                "type": ["string", "null"]
              },
              "pullRequests": {
                "type": "array",
                "items": {
                  "type": ["object", "null"]
                }
              },
              "dependencyContext": {
                "type": ["object", "null"]
              }
            }
          },
          "repositoryHints": {
            "type": ["object", "null"],
            "properties": {
              "suggestedBasePath": {
                "type": ["string", "null"]
              },
              "suggestedStableRepositoryId": {
                "type": ["string", "null"]
              }
            }
          }
        }
      },
      "prototypeImplementationGuidance": {
        "type": ["object", "null"]
      },
      "prototypeCodeMediaDownloads": {
        "type": ["array", "null"]
      },
      "execution": {
        "type": ["object", "null"],
        "properties": {
          "executionState": { "type": "string" },
          "claimedBy": { "type": ["string", "null"] },
          "claimedAt": { "type": ["string", "null"] },
          "branchName": { "type": ["string", "null"] },
          "providerPullRequestNumber": { "type": ["integer", "null"] },
          "providerPullRequestUrl": { "type": ["string", "null"] }
        }
      },
      "viewer": {
        "type": ["object", "null"],
        "properties": {
          "username": { "type": "string" },
          "email": { "type": "string" }
        }
      },
      "message": {
        "type": ["string", "null"]
      }
    }
  }
}
