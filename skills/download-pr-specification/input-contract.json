{
  "name": "download-pr-specification",
  "description": "Self-contained public skill that downloads the full build specification for a planned pull request within a canonical task.",
  "version": "1.1.1",
  "input": {
    "type": "object",
    "required": ["canonicalTaskId"],
    "properties": {
      "canonicalTaskId": {
        "type": "string",
        "pattern": "^[A-Z0-9]+-[1-9][0-9]*$",
        "description": "Canonical Itera task ID (for example FRONTPAGE-42)."
      },
      "pullRequestPosition": {
        "type": "integer",
        "minimum": 1,
        "description": "1-based planned pull request position inside the task plan."
      },
      "plannedPullRequestId": {
        "type": "string",
        "description": "Explicit Itera planned pull request ID."
      },
      "outputFile": {
        "type": "string",
        "description": "Optional explicit JSON artifact path."
      }
    },
    "additionalProperties": false,
    "anyOf": [
      {
        "required": ["pullRequestPosition"]
      },
      {
        "required": ["plannedPullRequestId"]
      }
    ]
  },
  "behavior": {
    "installEntryPoint": "python3 install.py",
    "sessionFile": "Target-specific default; Codex ~/.codex/auth/plan_execution/iteraz.json, Claude ~/.claude/auth/plan_execution/iteraz.json, Cursor ~/.cursor/auth/plan_execution/iteraz.json, Copilot/other ${XDG_CONFIG_HOME:-~/.config}/plan_execution/auth/iteraz.json",
    "defaultOutputFile": "~/.codex/artifacts/plan_execution/specifications/planned_pull_requests/<canonical-task-id-lower>/pr-<position>.json",
    "appHeader": "ITERAZ",
    "platformHeader": "WEB",
    "requiredGraphQLCalls": [
      "sendEmailVerificationCode(email)",
      "loginWithEmailMfa(identifier, code)",
      "completeEmailLoginWithTotp(challengeId, code)",
      "completeEmailLoginWithRecoveryCode(challengeId, code)",
      "beginTotpEnrollment",
      "confirmTotpEnrollment(code)",
      "refreshToken(refreshToken)",
      "socialMe",
      "getIterationTaskByCanonicalId(canonicalId)",
      "generateDownloadInformation(media)"
    ],
    "outputContains": [
      "full raw task payload",
      "selected planned pull request",
      "source task specification crosswalk",
      "dependency context",
      "repository hints",
      "downloaded prototype code media artifacts when present",
      "explicit prototype UI implementation guidance when prototype patches are attached, including a strict instruction to never build prototype canvas routes/pages and to use canvas contents only as state references"
    ]
  },
  "output": {
    "type": "object",
    "required": [
      "status",
      "canonicalTaskId",
      "snapshotFile"
    ],
    "properties": {
      "status": {
        "type": "string",
        "enum": [
          "SUCCESS",
          "AUTH_REQUIRED",
          "LOGIN_FAILED",
          "NOT_FOUND",
          "NO_PLAN",
          "PR_NOT_FOUND",
          "UNAVAILABLE"
        ]
      },
      "canonicalTaskId": {
        "type": "string"
      },
      "snapshotFile": {
        "type": ["string", "null"]
      },
      "plannedPullRequest": {
        "type": ["object", "null"]
      },
      "task": {
        "type": ["object", "null"]
      },
      "buildContext": {
        "type": ["object", "null"]
      },
      "prototypeImplementationGuidance": {
        "type": ["object", "null"]
      },
      "prototypeCodeMediaDownloads": {
        "type": ["array", "null"]
      },
      "viewer": {
        "type": ["object", "null"]
      },
      "message": {
        "type": ["string", "null"]
      }
    }
  }
}
